# -----------------------------------------------------------------------------
# DISCORD CONFIGURATION
# -----------------------------------------------------------------------------

# Le token secret de votre application Discord (Bot Token)
DISCORD_TOKEN=your_discord_bot_token_here

# L'ID de votre application Discord (Application ID)
CLIENT_ID=your_discord_client_id_here

# Note: GUILD_ID, TEAM_CATEGORY_ID and NOTIFICATION_CHANNEL_ID 
# are now managed dynamically via the /config command and stored in config.json

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------

# L'URL de votre projet Supabase (ex: https://abc.supabase.co)
SUPABASE_URL=your_supabase_project_url_here

# La clé API anonyme de votre projet Supabase
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# PLATFORM CONFIGURATION
# -----------------------------------------------------------------------------

# L'URL racine de votre plateforme web (utilisé pour les liens dans les messages)
WEBSITE_URL=http://localhost:5173
