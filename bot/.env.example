# -----------------------------------------------------------------------------
# DISCORD CONFIGURATION
# -----------------------------------------------------------------------------

# Le token secret de votre application Discord (Bot Token)
DISCORD_TOKEN=your_discord_bot_token_here

# L'ID de votre application Discord (Application ID)
CLIENT_ID=your_discord_client_id_here

# L'ID du serveur Discord (Guild ID) où les commandes seront enregistrées
GUILD_ID=your_discord_guild_id_here

# (Optionnel) L'ID de la catégorie où les salons d'équipe seront créés
TEAM_CATEGORY_ID=

# (Optionnel) L'ID du canal pour les notifications générales (Scrims, Patch Notes)
# Si laissé vide, le bot créera automatiquement un salon nommé #fwitter-league
NOTIFICATION_CHANNEL_ID=

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------

# L'URL de votre projet Supabase (ex: https://abc.supabase.co)
SUPABASE_URL=your_supabase_project_url_here

# La clé API anonyme de votre projet Supabase
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# PLATFORM CONFIGURATION
# -----------------------------------------------------------------------------

# L'URL racine de votre plateforme web (utilisé pour les liens dans les messages)
WEBSITE_URL=http://localhost:5173
