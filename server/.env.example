# --- CONFIGURATION SUPABASE (Requis) ---
# L'URL de ton projet Supabase (Settings > API)
SUPABASE_URL=https://lykrrunuztixrmcmvdrk.supabase.co

# La clé de service (Settings > API > service_role)
# ATTENTION : Cette clé bypass le RLS. Ne JAMAIS la partager publiquement.
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role_secrete

# --- CONFIGURATION RIOT API (Optionnel pour le développement) ---
# Ta clé de développement Riot (https://developer.riotgames.com/)
RIOT_API_KEY=RGAPI-votre-cle-ici
VITE_RIOT_API_KEY=RGAPI-votre-cle-ici

# --- CONFIGURATION SERVEUR ---
PORT=3000
NODE_ENV=development

# --- CLÉS POUR LE FRONTEND (Vite) ---
